# Copy this file to .env and fill in the values you need.
#
# .env now holds ONLY secrets (API keys + cloud credentials). All tunable
# behavior — provider selection, model paths, devices, and the vision debug
# toggle — lives in api/routes/config.toml.

# ---------------------------------------------------------------------------
# TTS — ElevenLabs (only needed when [tts] provider = "elevenlabs")
# ---------------------------------------------------------------------------
ELEVENLABS_API_KEY=

# ---------------------------------------------------------------------------
# Google Cloud (STT, image captioning via Gemini)
# Set GOOGLE_APPLICATION_CREDENTIALS to a service-account JSON path, OR
# set GOOGLE_API_KEY for API-key auth.
# ---------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_API_KEY=
