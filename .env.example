# Copy this file to .env and fill in the values you need.

# ---------------------------------------------------------------------------
# Vision debug
# When truthy (1/true/yes/on), each call to image_caption / object_detection /
# pose_estimation pops up a separate OpenCV window showing the input image,
# the inference overlay, and a text summary. Disable in production.
# Requires a display (X / Wayland) on the machine running the server.
# ---------------------------------------------------------------------------
VISION_DEBUG=false

# ---------------------------------------------------------------------------
# TTS — ElevenLabs
# ---------------------------------------------------------------------------
ELEVENLABS_API_KEY=

# ---------------------------------------------------------------------------
# Google Cloud (STT, image captioning via Gemini)
# Set GOOGLE_APPLICATION_CREDENTIALS to a service-account JSON path, OR
# set GOOGLE_API_KEY for API-key auth.
# ---------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_API_KEY=
